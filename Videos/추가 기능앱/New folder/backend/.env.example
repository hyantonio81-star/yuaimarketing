# PostgreSQL (필수. 로컬 서버 모드에서는 미설정 시 로그인 불가)
# Docker 사용 시: postgresql://kpi:kpi_secret@postgres:5432/kpi_db
# Supabase 배포 시: Supabase 대시보드 → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://user:password@localhost:5432/factory_kpi

# true면 DB 미연결 시 503 반환(로그인·API 불가). 로컬 서버 권장: true
REQUIRE_DATABASE=true
# health API 응답용: local | production
SERVER_MODE=local

# JWT (운영 환경에서는 반드시 변경)
JWT_SECRET=your-very-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 허용 출처 (쉼표 구분). Vercel 배포 시 https://your-app.vercel.app 추가
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limit (API 전역 한도는 단일 인스턴스 인메모리 기준, 다중 인스턴스 시 Redis 등 별도 고려)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_API_PER_MINUTE=120

# Supabase (선택. Realtime/Storage/Auth 연동 시. DB는 위 DATABASE_URL에 Supabase Connection string 사용)
# 대시보드: Settings → API → Project URL / anon public / service_role secret
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
