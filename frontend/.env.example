# Backend API (optional; default http://localhost:4000)
VITE_API_URL=http://localhost:4000

# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Use anon/public key in the frontend, never the service_role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Meta Pixel (Facebook Business Manager 연동 시, docs/FACEBOOK_BUSINESS_MANAGER_연계_시나리오.md 참고)
# VITE_META_PIXEL_ID=your-pixel-id
