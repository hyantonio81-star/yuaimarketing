# Backend API (optional; default http://localhost:4000)
VITE_API_URL=http://localhost:4000

# Show login screen first (true = always show /login until signed in or "Dev: skip login")
# Omit or false = when Supabase is not set, go straight to app without login
VITE_REQUIRE_LOGIN=true

# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Use anon/public key in the frontend, never the service_role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Meta Pixel (Facebook Business Manager 연동 시, docs/FACEBOOK_BUSINESS_MANAGER_연계_시나리오.md 참고)
# VITE_META_PIXEL_ID=your-pixel-id

# --- CI / dev-only (optional) ---
# CI 빌드에서 Supabase 키 없이 번들만 통과시킬 때 (로그인 동작 불가).
# GitHub Actions ci.yml에서 자동 주입됨; 로컬에서는 설정하지 마세요.
# VITE_ALLOW_BUILD_WITHOUT_SUPABASE=true

# 로컬 개발 시 로그인 화면을 건너뛸 때만 사용 (프로덕션에서는 절대 사용 금지).
# VITE_DEV_SKIP_AUTH=true
