# Server (PC/서버용: 같은 포트에서 API + 웹 서빙)
PORT=4000

# 로컬 개발: Vite http://localhost:5173 → API :4000 호출 시 CORS (비우면 개발에서 origin false일 수 있음)
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 프론트 빌드 폴더 경로 (비우면 backend/../frontend/dist 자동 사용)
# PUBLIC_DIR=/absolute/path/to/nexus-ai/frontend/dist

# Shorts: FFmpeg가 PATH에 없으면 실행 파일 전체 경로 (공백 포함 경로 가능)
# Windows: winget Gyan.FFmpeg, gyan.dev 빌드, 또는 BtbN https://github.com/BtbN/FFmpeg-Builds/releases (win64-gpl-shared → bin\ffmpeg.exe)
# https://www.ffmpeg.org/download.html — 소스(.tar.xz)는 컴파일용
# Vercel 서버리스에는 보통 FFmpeg 없음 → 원격 조립·워커 또는 별도 호스트 API (docs/SHORTS_AGENT.md)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# 원격 조립 워커 (로컬 PC에서 npm run shorts:assembly-worker) — Vercel과 동일 SHORTS_WORKER_SECRET 필수
# SHORTS_API_BASE=https://your-app.vercel.app/api/shorts
# SHORTS_WORKER_SECRET=long-random-secret-match-vercel-env

# Supabase (https://supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres password (Dashboard → Settings → Database). Needed for: npm run supabase:db-push
# SUPABASE_DB_PASSWORD=your-database-password
# Pooler AWS region (Dashboard → Connect → Session pooler host). Default in script: us-east-1
# SUPABASE_POOLER_REGION=us-west-2
# Optional: full URI overrides pooler/direct build
# SUPABASE_DATABASE_URL=postgresql://postgres:...@aws-0-....pooler.supabase.com:5432/postgres

# One-time seed (run: npm run seed-users)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your-secure-password
# Optional: additional user
# SEED_USER_EMAIL=user@example.com
# SEED_USER_PASSWORD=your-password

# 운영자 비밀번호 설정/생성 (run: npx tsx scripts/set-admin-password.ts). .env에만 설정, 저장소에 커밋 금지
# ADMIN_EMAIL=operator@example.com
# ADMIN_PASSWORD=your-secure-password

# Gemini (Threads Commerce AI copy - if set, uses Gemini; otherwise OpenAI)
# GEMINI_API_KEY=your-gemini-api-key

# Shein 제휴 피드 (쉬인 어필리에이트 가입 후 제공되는 CSV/XML URL)
# SHEIN_AFFILIATE_FEED_URL=https://...

# 시장 인텔 · 뉴스 (국가별 뉴스 요약, 리포트 파이프라인 포함)
# 설정 시 현지 뉴스 사용; 미설정 시 Reuters/BBC RSS만 사용
# NEWSDATA_API_KEY=your-newsdata-api-key
# MEDIASTACK_ACCESS_KEY=your-mediastack-access-key

# 시장 인텔 · 기업 DB (세분화 분석 시 관련 업체 추천, 리포트 파이프라인 포함)
# 미설정 시 OpenCorporates 무료 제한 적용
# OPENCOMPORATES_API_TOKEN=your-opencorporates-token

# Meta / Facebook Business Manager (픽셀·Conversions API 연동 시)
# META_PIXEL_ID=your-pixel-id
# META_APP_ID=your-app-id
# META_ACCESS_TOKEN=system-user-token-for-capi

# Tienda 운영자 로그인 (yuaimarketing 랜딩 /tienda-admin) — 필수
# 미설정 시 로그인 API가 503을 반환합니다. Vercel(백엔드 프로젝트)에도 동일 키로 설정하세요.
# LANDING_ADMIN_PASSWORD=your-secure-password-min-8-chars

# Admin 첫 생성용 bootstrap (프로덕션에서는 기본 비활성. 첫 admin 만든 뒤 false 권장)
# ADMIN_BOOTSTRAP_ENABLED=true

# SPA 로그인 후 돌아올 프론트 origin (미설정 시 Vercel x-forwarded-host 등으로 추론). YouTube OAuth 콜백 후 리다이렉트에 사용
# FRONTEND_ORIGIN=https://your-app.vercel.app

# CORS 허용 origin 목록 (쉼표로 구분). 운영/프로덕션에서는 필수.
# - 예: ALLOWED_ORIGINS=https://yuaimarketing.vercel.app,https://yuaimarketing-landing.vercel.app
#
# FRONTEND_ORIGIN만 있어도 개발/로컬에서는 동작하지만, Vercel 프로덕션 배포에서는 ALLOWED_ORIGINS를 명시하는 것을 권장합니다.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-landing.vercel.app
#
# 랜딩 origin을 별도로 두고 싶을 때만 사용합니다.
# LANDING_ORIGIN=https://your-landing.vercel.app

# YouTube Shorts OAuth (설정 시 연동 페이지에서 계정 연결 가능)
# YOUTUBE_CLIENT_ID=your-client-id
# YOUTUBE_CLIENT_SECRET=your-client-secret
# 로컬: 아래 / Vercel Production: https://<배포호스트>/api/shorts/youtube/callback (Google Console 승인 URI와 1:1 동일)
# YOUTUBE_REDIRECT_URI=http://localhost:4000/api/shorts/youtube/callback
# OAuth state HMAC — Vercel/프로덕션에서 필수. 없으면 토큰이 레거시 placeholder user에만 저장되어 UI는 항상 「미연동」.
# CONNECTION_PIN_SECRET 을 이미 쓰면 그 값으로 state 서명에 재사용됩니다.
# state에 Supabase auth user id 포함 → 콜백 시 해당 사용자 행에 토큰 저장 (테이블: youtube_oauth_store)
# YOUTUBE_OAUTH_STATE_SECRET=long-random-secret
# 토큰 암호화 영속화 (64자 hex 또는 16자 이상 비밀문자). 설정 시 재시작 후에도 연동 유지
# YOUTUBE_TOKEN_ENCRYPTION_KEY=your-64-char-hex-or-password

# Shorts 원격 FFmpeg 조립 (Vercel 등: 로컬 조립 불가 시 pending_assembly → 외부 워커가 완료)
# SHORTS_DELEGATE_ASSEMBLY=1  — FFmpeg 없어도 매니페스트 업로드 후 큐잉 (VERCEL=1일 때와 함께 쓰기)
# SHORTS_DISABLE_REMOTE_ASSEMBLY=1 — 원격 조립 경로 끄기 (헬스의 remoteAssemblyEnabled=false)
#
# YouTube 업로드 기본 공개 범위: private | unlisted | public
# YOUTUBE_UPLOAD_PRIVACY=private
# 업로드 후 processingStatus 폴링 (0이면 업로드 직후 응답만)
# YOUTUBE_POLL_PROCESSING=1
#
# 원격 조립 워커 스크립트: repo 루트에서 SHORTS_API_BASE, SHORTS_WORKER_SECRET 설정 후
#   npm run shorts:assembly-worker
# SHORTS_API_BASE=https://your-host/api/shorts
# SHORTS_ASSEMBLY_LIMIT=3

# Shorts 배포 큐 워커 (Cron/VM용) — 1회 실행 API 호출용 비밀키
# 이 값이 없으면 /api/shorts/distribution/queue/process 엔드포인트 호출이 거부됩니다.
# SHORTS_WORKER_SECRET=your-strong-secret
#
# 로컬/운영 스케줄러에서 스크립트 호출 시 endpoint를 바꾸고 싶으면 아래를 사용합니다.
# SHORTS_WORKER_ENDPOINT=http://localhost:4000/api/shorts/distribution/queue/process
# SHORTS_WORKER_LIMIT=5

# 운영에서 Supabase가 진짜 소스가 되도록 파일 폴백을 차단할지 결정합니다.
# - 기본값: 운영(production)에서는 false(폴백 비활성)
# - 개발에서는 자동으로 true(폴백 허용)
# SHORTS_JOB_FILE_FALLBACK=true
#
# Vercel(VERCEL=1): 배포 번들(/var/task)은 읽기 전용 → data·Shorts 스토리지 등은 코드상 /tmp/nexus-ai-data 를 사용합니다.
# Shorts 파일 경로를 직접 지정하려면: SHORTS_STORAGE_PATH=/절대/경로
