{
  "name": "nexus-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": { "node": ">=18.x <=20.x" },
  "workspaces": ["frontend", "backend", "landing"],
  "overrides": {
    "tar": ">=6.2.2",
    "glob": ">=10.4.5",
    "rimraf": ">=5.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:landing": "cd landing && npm run dev",
    "lint": "eslint .",
    "test": "npm --workspace backend run test",
    "format": "prettier --write .",
    "build": "cd backend && npm run build && cd ../frontend && npm run build && cd ../landing && npm run build",
    "start": "npm run build && npm run start:server",
    "start:server": "node scripts/start-server.js",
    "check-setup": "node scripts/check-setup.js",
    "ffmpeg:install-win": "powershell -ExecutionPolicy Bypass -File scripts/install-ffmpeg-windows.ps1",
    "vercel:set-root": "node scripts/vercel-set-root.js",
    "supabase:db-push": "node scripts/supabase-db-push.mjs",
    "shorts:assembly-worker": "node scripts/shorts-assembly-worker.mjs"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "prettier": "^3.2.0"
  }
}
